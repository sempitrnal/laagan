# Copy this file to .env.local and fill in your Firebase config
# to enable real-time collaboration across devices.
#
# Setup:
#   1. Go to https://console.firebase.google.com
#   2. Create a new project
#   3. Add a Web App and copy the config below
#   4. In Firestore > Rules, use:
#        rules_version = '2';
#        service cloud.firestore {
#          match /databases/{database}/documents {
#            match /trips/{tripId} {
#              allow read, write: if true;
#              match /expenses/{expenseId} {
#                allow read, write: if true;
#              }
#            }
#          }
#        }
#
# Without this file, the app runs in local mode (data saved to
# this browser only — sharing still works on the same device).

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
